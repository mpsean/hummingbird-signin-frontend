pipeline {
    agent any

    parameters {
        string(name: 'DOCKER_CREDENTIALS_ID', defaultValue: 'dockerhub-credentials', description: 'Jenkins Username/Password credentials ID for Docker Hub')
        string(name: 'DOCKER_IMAGE', defaultValue: 'pemapol/hummingbird-signin-frontend', description: 'Docker image repository (e.g. username/repository)')
    }

    options {
        skipDefaultCheckout(true)
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 40, unit: 'MINUTES')
    }

    triggers {
        pollSCM('H/2 * * * *')
    }
    
    environment {
        CI = 'true'
        DOCKER_IMAGE = "${params.DOCKER_IMAGE}"
    }
    stages {
        stage('Checkout Source') {
            steps {
                deleteDir()
                checkout scm
            }
        }
        stage('Setup Node Runtime') {
            steps {
                sh '''#!/bin/sh
set -e

ARCH="$(uname -m)"
case "${ARCH}" in
  x86_64) NODE_ARCH='x64' ;;
  aarch64|arm64) NODE_ARCH='arm64' ;;
  *)
    echo "Unsupported architecture: ${ARCH}" >&2
    exit 1
    ;;
esac

mkdir -p .ci
NODE_HOME="$PWD/.ci/node"

if [ ! -x "${NODE_HOME}/bin/node" ]; then
  NODE_FILE="$(curl -fsSL https://nodejs.org/dist/latest-v20.x/SHASUMS256.txt | awk -v arch="${NODE_ARCH}" '$2 ~ ("linux-" arch "\\.tar\\.gz$") {print $2; exit}')"
  if [ -z "${NODE_FILE}" ]; then
    echo 'Unable to resolve Node.js download filename.' >&2
    exit 1
  fi

  curl -fsSL "https://nodejs.org/dist/latest-v20.x/${NODE_FILE}" -o .ci/node.tar.gz
  rm -rf "${NODE_HOME}"
  mkdir -p "${NODE_HOME}"
  tar -xzf .ci/node.tar.gz --strip-components=1 -C "${NODE_HOME}"
  rm -f .ci/node.tar.gz
fi

export PATH="${NODE_HOME}/bin:${PATH}"
node -v
npm -v
'''
            }
        }
        stage('Install Dependencies') {
            steps {
                sh 'export PATH="$PWD/.ci/node/bin:$PATH" && npm ci --no-audit --no-fund'
            }
        }
        stage('Test') {
            steps {
                sh 'mkdir -p test-results'
                sh 'export PATH="$PWD/.ci/node/bin:$PATH" && sh ./jenkins/scripts/test.sh'
            }
            post {
                always {
                    junit testResults: 'test-results/junit.xml', allowEmptyResults: false
                }
            }
        }
        stage('Prune Local Build Artifacts') {
            steps {
                sh '''#!/bin/sh
set -eu

# Reduce controller disk pressure before image build.
rm -rf node_modules .npm .ci/node .ci/node.tar.gz || true
'''
            }
        }
        stage('Build And Push Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: params.DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_TOKEN')]) {
                    sh '''#!/bin/sh
set -eu

if ! command -v docker >/dev/null 2>&1; then
    echo 'docker CLI is required on the Jenkins agent for direct build/push mode.' >&2
    exit 1
fi

# Install docker buildx plugin if not present.
if ! docker buildx version >/dev/null 2>&1; then
    echo 'docker buildx not found — installing...'
    ARCH="$(uname -m)"
    case "${ARCH}" in
        x86_64)  BUILDX_ARCH='amd64' ;;
        aarch64|arm64) BUILDX_ARCH='arm64' ;;
        *) echo "Unsupported architecture: ${ARCH}" >&2; exit 1 ;;
    esac
    BUILDX_VERSION="$(curl -fsSL https://api.github.com/repos/docker/buildx/releases/latest \
        | grep '"tag_name"' | head -1 | cut -d'"' -f4)"
    mkdir -p /usr/local/lib/docker/cli-plugins
    curl -fsSL "https://github.com/docker/buildx/releases/download/${BUILDX_VERSION}/buildx-${BUILDX_VERSION}.linux-${BUILDX_ARCH}" \
        -o /usr/local/lib/docker/cli-plugins/docker-buildx
    chmod +x /usr/local/lib/docker/cli-plugins/docker-buildx
    echo "Installed docker buildx ${BUILDX_VERSION}"
fi

# Register QEMU emulators for cross-platform builds.
docker run --rm --privileged tonistiigi/binfmt --install all

echo "${DOCKERHUB_TOKEN}" | docker login -u "${DOCKERHUB_USERNAME}" --password-stdin

# Create a fresh multi-platform builder for this build.
BUILDER_NAME="ci-builder-${BUILD_NUMBER}"
docker buildx create --name "${BUILDER_NAME}" --use --bootstrap
trap 'docker buildx rm "${BUILDER_NAME}" 2>/dev/null || true' EXIT

docker buildx build \
  --platform linux/amd64,linux/arm64 \
  --build-arg VITE_API_URL=http://signin.hmmbird.xyz \
  --build-arg VITE_API_URL=http://hummingbird-api.hummingbird-api.svc.cluster.local:5000 \
  -f .Dockerfile \
  -t "${DOCKER_IMAGE}:${BUILD_NUMBER}" \
  -t "${DOCKER_IMAGE}:latest" \
  --push \
  .

docker logout
echo 'Multi-platform image pushed successfully.'
'''
                }
            }
        }
    }

    post {
        always {
            // Prevent Jenkins controller disk growth from repeated Node/Kaniko runs.
            deleteDir()
            sh 'docker system prune -f --volumes'
        }
    }
}

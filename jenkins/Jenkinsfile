pipeline {
    agent any

    parameters {
        string(name: 'DOCKER_CREDENTIALS_ID', defaultValue: 'dockerhub-credentials', description: 'Jenkins Username/Password credentials ID for Docker Hub')
        string(name: 'DOCKER_IMAGE', defaultValue: 'pemapol/hummingbird-signin-frontend', description: 'Docker image repository (e.g. username/repository)')
        string(name: 'GIT_REPO_URL', defaultValue: 'https://github.com/mpsean/hummingbird-signin-frontend.git', description: 'Git repository URL for Kaniko build context')
        string(name: 'GIT_REF', defaultValue: 'master', description: 'Git branch or ref to build')
    }

    options {
        skipDefaultCheckout(true)
    }

    triggers {
        pollSCM('H/2 * * * *')
    }
    
    environment {
        CI = 'true'
        DOCKER_IMAGE = "${params.DOCKER_IMAGE}"
    }
    stages {
        stage('Checkout Source') {
            steps {
                deleteDir()
                checkout scm
            }
        }
        stage('Setup Node Runtime') {
            steps {
                sh '''#!/bin/sh
set -e

ARCH="$(uname -m)"
case "${ARCH}" in
  x86_64) NODE_ARCH='x64' ;;
  aarch64|arm64) NODE_ARCH='arm64' ;;
  *)
    echo "Unsupported architecture: ${ARCH}" >&2
    exit 1
    ;;
esac

mkdir -p .ci
NODE_HOME="$PWD/.ci/node"

if [ ! -x "${NODE_HOME}/bin/node" ]; then
  NODE_FILE="$(curl -fsSL https://nodejs.org/dist/latest-v20.x/SHASUMS256.txt | awk -v arch="${NODE_ARCH}" '$2 ~ ("linux-" arch "\\.tar\\.gz$") {print $2; exit}')"
  if [ -z "${NODE_FILE}" ]; then
    echo 'Unable to resolve Node.js download filename.' >&2
    exit 1
  fi

  curl -fsSL "https://nodejs.org/dist/latest-v20.x/${NODE_FILE}" -o .ci/node.tar.gz
  rm -rf "${NODE_HOME}"
  mkdir -p "${NODE_HOME}"
  tar -xzf .ci/node.tar.gz --strip-components=1 -C "${NODE_HOME}"
  rm -f .ci/node.tar.gz
fi

export PATH="${NODE_HOME}/bin:${PATH}"
node -v
npm -v
'''
            }
        }
            stage('Setup Kubectl') {
                steps {
                sh '''#!/bin/sh
set -e

ARCH="$(uname -m)"
case "${ARCH}" in
    x86_64) K_ARCH='amd64' ;;
    aarch64|arm64) K_ARCH='arm64' ;;
    *)
        echo "Unsupported architecture for kubectl: ${ARCH}" >&2
        exit 1
        ;;
esac

mkdir -p .ci/kubectl/bin

if [ ! -x .ci/kubectl/bin/kubectl ]; then
    K_VER="$(curl -fsSL https://dl.k8s.io/release/stable.txt)"
    curl -fsSL "https://dl.k8s.io/release/${K_VER}/bin/linux/${K_ARCH}/kubectl" -o .ci/kubectl/bin/kubectl
    chmod +x .ci/kubectl/bin/kubectl
fi

export PATH="$PWD/.ci/kubectl/bin:$PATH"
kubectl version --client
'''
        }
    }
        stage('Install Dependencies') {
            steps {
                sh 'export PATH="$PWD/.ci/node/bin:$PATH" && npm ci'
            }
        }
        stage('Test') {
            steps {
                sh 'export PATH="$PWD/.ci/node/bin:$PATH" && sh ./jenkins/scripts/test.sh'
            }
        }
        stage('Build Application') {
            steps {
                sh 'export PATH="$PWD/.ci/node/bin:$PATH" && npm run build'
            }
        }
        stage('Build And Push Image (Kaniko)') {
            steps {
                withCredentials([usernamePassword(credentialsId: params.DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_TOKEN')]) {
                    sh '''#!/bin/sh
set -eu

export PATH="$PWD/.ci/kubectl/bin:$PATH"

mkdir -p .ci

DOCKER_AUTH="$(printf '%s:%s' "$DOCKERHUB_USERNAME" "$DOCKERHUB_TOKEN" | base64 | tr -d '\\n')"
cat > .ci/kaniko-docker-config.json <<EOF
{
    "auths": {
        "https://index.docker.io/v1/": {
            "auth": "${DOCKER_AUTH}"
        }
    }
}
EOF

SECRET_NAME="kaniko-docker-config-${BUILD_NUMBER}"
POD_NAME="kaniko-build-${BUILD_NUMBER}"

cleanup() {
    kubectl -n devops-tools delete pod "${POD_NAME}" --ignore-not-found=true >/dev/null 2>&1 || true
    kubectl -n devops-tools delete secret "${SECRET_NAME}" --ignore-not-found=true >/dev/null 2>&1 || true
}
trap cleanup EXIT

kubectl -n devops-tools delete pod "${POD_NAME}" --ignore-not-found=true >/dev/null 2>&1 || true

kubectl -n devops-tools create secret generic "$SECRET_NAME" \
    --from-file=config.json=.ci/kaniko-docker-config.json \
    --dry-run=client -o yaml | kubectl apply -f -

cat <<EOF | kubectl -n devops-tools apply -f -
apiVersion: v1
kind: Pod
metadata:
  name: ${POD_NAME}
spec:
  restartPolicy: Never
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:latest
    args:
    - --context=git://${GIT_REPO_URL}#refs/heads/${GIT_REF}
    - --dockerfile=.Dockerfile
    - --destination=${DOCKER_IMAGE}:${BUILD_NUMBER}
    - --destination=${DOCKER_IMAGE}:latest
    volumeMounts:
    - name: docker-config
      mountPath: /kaniko/.docker
      readOnly: true
  volumes:
  - name: docker-config
    secret:
      secretName: ${SECRET_NAME}
      items:
      - key: config.json
        path: config.json
EOF

kubectl -n devops-tools wait --for=condition=PodScheduled pod/${POD_NAME} --timeout=120s
kubectl -n devops-tools logs -f pod/${POD_NAME} || true

# Wait for Kaniko pod to finish and then evaluate status.
kubectl -n devops-tools wait --for=jsonpath='{.status.phase}'=Succeeded pod/${POD_NAME} --timeout=3600s || true

POD_PHASE="$(kubectl -n devops-tools get pod ${POD_NAME} -o jsonpath='{.status.phase}' 2>/dev/null || true)"
EXIT_CODE="$(kubectl -n devops-tools get pod ${POD_NAME} -o jsonpath='{.status.containerStatuses[0].state.terminated.exitCode}' 2>/dev/null || true)"

if [ "${POD_PHASE}" = "Failed" ]; then
    kubectl -n devops-tools describe pod ${POD_NAME} || true
fi

if [ "${POD_PHASE}" != "Succeeded" ] || [ "${EXIT_CODE}" != "0" ]; then
    echo "Kaniko build failed (phase=${POD_PHASE}, exit=${EXIT_CODE})" >&2
    exit 1
fi
'''
                }
            }
        }
    }
}

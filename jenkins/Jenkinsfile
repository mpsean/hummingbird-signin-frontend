pipeline {
    agent any

    tools { nodejs "nodejs" }

    environment {
        CI = 'true'
        DOCKER_IMAGE = 'mpsean/hummingbird-signin-frontend'
    }
    stages {
        stage('Install Dependencies') {
            steps {
                sh '''#!/bin/sh
set -e

install_with_apt() {
    if command -v sudo >/dev/null 2>&1; then
        sudo apt-get update && sudo apt-get install -y libatomic1
    else
        apt-get update && apt-get install -y libatomic1
    fi
}

install_with_yum() {
    if command -v sudo >/dev/null 2>&1; then
        sudo yum install -y libatomic
    else
        yum install -y libatomic
    fi
}

install_with_dnf() {
    if command -v sudo >/dev/null 2>&1; then
        sudo dnf install -y libatomic
    else
        dnf install -y libatomic
    fi
}

if command -v apt-get >/dev/null 2>&1; then
    install_with_apt
elif command -v yum >/dev/null 2>&1; then
    install_with_yum
elif command -v dnf >/dev/null 2>&1; then
    install_with_dnf
else
    echo "Unsupported package manager. Install libatomic manually on the Jenkins agent."
    exit 1
fi

npm ci
'''
            }
        }
        stage('Test') {
            steps {
                sh './jenkins/scripts/test.sh'
            }
        }
        stage('Build Application') {
            steps {
                sh 'npm run build'
            }
        }
        stage('Build Docker Image') {
            steps {
                sh 'docker build -f .Dockerfile -t ${DOCKER_IMAGE}:${BUILD_NUMBER} -t ${DOCKER_IMAGE}:latest .'
            }
        }
        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_TOKEN')]) {
                    sh './jenkins/scripts/deliver.sh'
                }
            }
        }
    }
}
